## =================================================================
## ELEMENTS — NAMED DATA PROPERTIES
## =================================================================
## Data-carrying XML child elements (not references to other objects,
## not XML attributes like @id/@version).
## Only elements constrained by profiles need to be listed here.
## -----------------------------------------------------------------

netex:Element a owl:Class ;
    rdfs:label "Element" ;
    skos:definition "A data-carrying XML child element within a NeTEx object" .

## --- ResourceFrame elements ---

netex:Authority_Name a netex:Element ;
    rdfs:label "Authority → Name" ;
    netex:onClass netex:Authority ;
    netex:xsdCardinality "0..1" .

netex:Operator_Name a netex:Element ;
    rdfs:label "Operator → Name" ;
    netex:onClass netex:Operator ;
    netex:xsdCardinality "0..1" .

netex:VehicleType_Name a netex:Element ;
    rdfs:label "VehicleType → Name" ;
    netex:onClass netex:VehicleType ;
    netex:xsdCardinality "0..1" .

## --- SiteFrame elements ---

netex:StopPlace_ValidBetween a netex:Element ;
    rdfs:label "StopPlace → ValidBetween" ;
    netex:onClass netex:StopPlace ;
    netex:xsdCardinality "0..1" .

netex:StopPlace_AccessibilityAssessment a netex:Element ;
    rdfs:label "StopPlace → AccessibilityAssessment" ;
    netex:onClass netex:StopPlace ;
    netex:xsdCardinality "0..1" .

netex:Quay_AccessibilityAssessment a netex:Element ;
    rdfs:label "Quay → AccessibilityAssessment" ;
    netex:onClass netex:Quay ;
    netex:xsdCardinality "0..1" .

netex:Quay_boardingPositions a netex:Element ;
    rdfs:label "Quay → boardingPositions" ;
    netex:onClass netex:Quay ;
    netex:xsdCardinality "0..1" .

## --- ServiceFrame elements ---

netex:Line_TransportSubmode a netex:Element ;
    rdfs:label "Line → TransportSubmode" ;
    netex:onClass netex:Line ;
    netex:xsdCardinality "0..1" .

netex:Line_PublicCode a netex:Element ;
    rdfs:label "Line → PublicCode" ;
    netex:onClass netex:Line ;
    netex:xsdCardinality "0..1" .

netex:Line_PrivateCode a netex:Element ;
    rdfs:label "Line → PrivateCode" ;
    netex:onClass netex:Line ;
    netex:xsdCardinality "0..1" .

netex:ServiceJourney_FlexibleLineRef a netex:Reference ;
    rdfs:label "ServiceJourney → FlexibleLineRef" ;
    netex:onClass netex:ServiceJourney ;
    netex:target netex:Line ;
    netex:xsdCardinality "0..1" ;
    rdfs:comment "Reference to FlexibleLine (subtype of Line)" .

## --- FareFrame elements ---

netex:FareZone_Name a netex:Element ;
    rdfs:label "FareZone → Name" ;
    netex:onClass netex:FareZone ;
    netex:xsdCardinality "0..1" .

## --- TimetableFrame elements ---

netex:TimetabledPassingTime_ArrivalTime a netex:Element ;
    rdfs:label "TimetabledPassingTime → ArrivalTime" ;
    netex:onClass netex:TimetabledPassingTime ;
    netex:xsdCardinality "0..1" .

netex:TimetabledPassingTime_DepartureTime a netex:Element ;
    rdfs:label "TimetabledPassingTime → DepartureTime" ;
    netex:onClass netex:TimetabledPassingTime ;
    netex:xsdCardinality "0..1" .

netex:ServiceJourney_TransportMode a netex:Element ;
    rdfs:label "ServiceJourney → TransportMode" ;
    netex:onClass netex:ServiceJourney ;
    netex:xsdCardinality "0..1" .

netex:ServiceJourney_TransportSubmode a netex:Element ;
    rdfs:label "ServiceJourney → TransportSubmode" ;
    netex:onClass netex:ServiceJourney ;
    netex:xsdCardinality "0..1" .

netex:DatedServiceJourney_ServiceAlteration a netex:Element ;
    rdfs:label "DatedServiceJourney → ServiceAlteration" ;
    netex:onClass netex:DatedServiceJourney ;
    netex:xsdCardinality "0..1" .

netex:StopPointInJourneyPattern_ForBoarding a netex:Element ;
    rdfs:label "StopPointInJourneyPattern → ForBoarding" ;
    netex:onClass netex:StopPointInJourneyPattern ;
    netex:xsdCardinality "0..1" .

netex:StopPointInJourneyPattern_ForAlighting a netex:Element ;
    rdfs:label "StopPointInJourneyPattern → ForAlighting" ;
    netex:onClass netex:StopPointInJourneyPattern ;
    netex:xsdCardinality "0..1" .

## --- Rolling stock elements ---

netex:TrainComponent_Label a netex:Element ;
    rdfs:label "TrainComponent → Label" ;
    netex:onClass netex:TrainComponent ;
    netex:xsdCardinality "0..1" .

netex:TrainComponent_OperationalOrientation a netex:Element ;
    rdfs:label "TrainComponent → OperationalOrientation" ;
    netex:onClass netex:TrainComponent ;
    netex:xsdCardinality "0..1" .

netex:Train_TypeOfFuel a netex:Element ;
    rdfs:label "Train → TypeOfFuel" ;
    netex:onClass netex:Train ;
    netex:xsdCardinality "0..1" .

netex:Network_Name a netex:Element ;
    rdfs:label "Network → Name" ;
    netex:onClass netex:Network ;
    netex:xsdCardinality "0..1" .

## =================================================================
## SIRI REAL-TIME BRIDGES
## =================================================================

siri:SIRI_ET a siri:Service ;
    rdfs:label "SIRI-ET — Estimated Timetable" ;
    siri:externalRepo "Profile_Documentation_SIRI" .

siri:SIRI_SX a siri:Service ;
    rdfs:label "SIRI-SX — Situation Exchange" ;
    siri:externalRepo "Profile_Documentation_SIRI" .

siri:SIRI_VM a siri:Service ;
    rdfs:label "SIRI-VM — Vehicle Monitoring" ;
    siri:externalRepo "Profile_Documentation_SIRI" .

siri:SIRI_FM a siri:Service ;
    rdfs:label "SIRI-FM — Facility Monitoring" ;
    siri:externalRepo "Profile_Documentation_SIRI" .

netex:Line netex:referencedBySIRI siri:SIRI_ET , siri:SIRI_SX , siri:SIRI_VM , siri:SIRI_FM ;
    rdfs:comment "Via LineRef in EstimatedVehicleJourney, MonitoredVehicleJourney, AffectedLine, FacilityLocation" .

netex:Route netex:referencedBySIRI siri:SIRI_ET , siri:SIRI_SX ;
    rdfs:comment "Via RouteRef in EstimatedVehicleJourney (mandatory for replacements), AffectedRoute" .

netex:ServiceJourney netex:referencedBySIRI siri:SIRI_ET , siri:SIRI_VM , siri:SIRI_SX ;
    rdfs:comment "Via FramedVehicleJourneyRef / DatedVehicleJourneyRef" .

netex:DatedServiceJourney netex:referencedBySIRI siri:SIRI_ET , siri:SIRI_VM , siri:SIRI_SX , siri:SIRI_FM ;
    rdfs:comment "Via DatedVehicleJourneyRef in all services" .

netex:JourneyPattern netex:referencedBySIRI siri:SIRI_ET ;
    rdfs:comment "Via JourneyPatternRef in EstimatedVehicleJourney" .

netex:Operator netex:referencedBySIRI siri:SIRI_ET , siri:SIRI_VM , siri:SIRI_SX , siri:SIRI_FM ;
    rdfs:comment "Via OperatorRef in all services" .

netex:Quay netex:referencedBySIRI siri:SIRI_ET , siri:SIRI_VM , siri:SIRI_SX ;
    rdfs:comment "Via StopPointRef in EstimatedCall, RecordedCall, MonitoredCall, AffectedStopPoint" .

netex:StopPlace netex:referencedBySIRI siri:SIRI_SX , siri:SIRI_FM , siri:SIRI_VM ;
    rdfs:comment "Via StopPlaceRef in AffectedStopPlace, FacilityLocation; OriginRef/DestinationRef in VM" .

netex:GroupOfLines netex:referencedBySIRI siri:SIRI_ET , siri:SIRI_SX ;
    rdfs:comment "Via GroupOfLinesRef (ET, mandatory for replacements), NetworkRef (SX AffectedNetwork)" .

## =================================================================
## TRANSMODEL ALIGNMENT
## =================================================================

netex:Authority skos:exactMatch tm-org:Authority ;
    rdfs:seeAlso tm-org:Organisation .

netex:Operator skos:exactMatch tm-org:Operator ;
    rdfs:seeAlso tm-org:Organisation .

netex:StopPlace skos:exactMatch tm-fac:StopPlace .
netex:Quay skos:exactMatch tm-fac:Quay .
netex:TopographicPlace skos:closeMatch tm-journeys:TopographicPlace .
netex:Parking skos:closeMatch tm-fac:Garage .

netex:Line skos:exactMatch tm-journeys:Line .
netex:Route skos:exactMatch tm-journeys:Route .
netex:JourneyPattern skos:exactMatch tm-journeys:JourneyPattern .
netex:ScheduledStopPoint skos:exactMatch tm-journeys:ScheduledStopPoint .
netex:DestinationDisplay skos:exactMatch tm-journeys:DestinationDisplay .
netex:Network skos:closeMatch tm-commons:GroupOfEntities .

netex:ServiceJourney skos:exactMatch tm-journeys:ServiceJourney .
netex:DatedServiceJourney skos:closeMatch tm-journeys:DatedVehicleJourney ;
    rdfs:comment "closeMatch (not exactMatch): CEN NeTEx issue #292 shows active disagreement on whether DatedServiceJourney truly maps to Transmodel DatedVehicleJourney. The alignment is approximate." .
netex:Interchange skos:closeMatch tm-journeys:Connection .
netex:StopPointInJourneyPattern skos:exactMatch tm-journeys:StopPointInJourneyPattern .

netex:DayType skos:exactMatch tm-journeys:DayType .
netex:DayTypeAssignment skos:exactMatch tm-journeys:DayTypeAssignment .
netex:OperatingPeriod skos:exactMatch tm-journeys:OperatingPeriod .
netex:OperatingDay skos:exactMatch tm-journeys:OperatingDay .

netex:Vehicle skos:closeMatch tm-journeys:Vehicle .

netex:ShelterEquipment skos:exactMatch tm-fac:ShelterEquipment .
netex:WaitingRoomEquipment skos:exactMatch tm-fac:WaitingRoomEquipment .
netex:SanitaryEquipment skos:exactMatch tm-fac:SanitaryEquipment .
netex:TicketingEquipment skos:exactMatch tm-fac:TicketingEquipment .

netex:TariffZone skos:closeMatch tm-commons:Zone .
netex:FareZone skos:closeMatch tm-commons:Zone .

netex:AccessibilityAssessment skos:exactMatch tm-fac:AccessibilityAssessment .

## =================================================================
## ADDITIONAL CLASSES (referenced by national profiles)
## =================================================================

netex:AccessibilityAssessment a owl:Class ;
    rdfs:label "AccessibilityAssessment" ;
    skos:definition "Assessment of accessibility features (wheelchair, step-free, etc.)" .

netex:AccessSpace a owl:Class ;
    rdfs:label "AccessSpace" ;
    skos:definition "Pedestrian area within a stop providing access between entrances and quays" ;
    netex:childOf netex:StopPlace .

netex:AvailabilityCondition a owl:Class ;
    rdfs:label "AvailabilityCondition" ;
    skos:definition "Condition specifying when an entity is valid (date range + optional day filter)" .

netex:BookingArrangements a owl:Class ;
    rdfs:label "BookingArrangements" ;
    skos:definition "Booking rules for demand-responsive or reservable services" .

netex:Branding a owl:Class ;
    rdfs:label "Branding" ;
    skos:definition "Visual identity (logo, colour scheme) for an operator or line" .

netex:CalendarChain a owl:Class ;
    rdfs:label "CalendarChain" ;
    skos:definition "Linked sequence of calendar periods for chaining validity" .

netex:Centroid a owl:Class ;
    rdfs:label "Centroid" ;
    skos:definition "Geographic centre point (Location with Longitude/Latitude)" .

netex:CheckConstraint a owl:Class ;
    rdfs:label "CheckConstraint" ;
    skos:definition "Security or ticket check constraint at a stop (gates, barriers)" ;
    netex:childOf netex:StopPlace .

netex:Connection a owl:Class ;
    rdfs:label "Connection" ;
    skos:definition "Transfer connection between two scheduled stop points with walk duration" ;
    netex:inFrame netex:ServiceFrame .

netex:ContactDetails a owl:Class ;
    rdfs:label "ContactDetails" ;
    skos:definition "Contact information (phone, email, URL)" .

netex:DayTypeAssignment a owl:Class ;
    rdfs:label "DayTypeAssignment" ;
    skos:definition "Binds a DayType to a specific date or OperatingPeriod" ;
    netex:inFrame netex:ServiceCalendarFrame .

netex:DefaultConnection a owl:Class ;
    rdfs:label "DefaultConnection" ;
    skos:definition "Default transfer time between stop points or within a stop" ;
    netex:inFrame netex:ServiceFrame .

netex:DeliveryVariant a owl:Class ;
    rdfs:label "DeliveryVariant" ;
    skos:definition "Variant of a Notice text for different media (print, audio, display)" .

netex:Destination a owl:Class ;
    rdfs:label "Destination" ;
    skos:definition "Destination information attached to a journey" .

netex:DestinationDisplayVariant a owl:Class ;
    rdfs:label "DestinationDisplayVariant" ;
    skos:definition "Media-specific variant of DestinationDisplay text" ;
    netex:childOf netex:DestinationDisplay .

netex:Direction a owl:Class ;
    rdfs:label "Direction" ;
    skos:definition "Named direction (inbound/outbound or custom)" ;
    netex:inFrame netex:ServiceFrame .

netex:DriverScheduleFrame a owl:Class ;
    rdfs:label "DriverScheduleFrame" ;
    skos:definition "Frame for driver duty and roster data" ;
    netex:containedIn netex:CompositeFrame .

netex:DynamicStopAssignment a owl:Class ;
    rdfs:label "DynamicStopAssignment" ;
    skos:definition "Real-time platform/quay assignment (overrides PassengerStopAssignment)" .

netex:Entrance a owl:Class ;
    rdfs:label "Entrance" ;
    skos:definition "Physical entrance to a StopPlace" ;
    netex:childOf netex:StopPlace .

netex:FareProduct a owl:Class ;
    rdfs:label "FareProduct" ;
    skos:definition "A purchasable fare product (ticket, pass, carnet)" ;
    netex:inFrame netex:FareFrame .

netex:FlexibleLine a owl:Class ;
    rdfs:label "FlexibleLine" ;
    skos:definition "Line with demand-responsive or flexible routing" ;
    rdfs:subClassOf netex:Line ;
    netex:inFrame netex:ServiceFrame .

netex:FlexibleLinkProperties a owl:Class ;
    rdfs:label "FlexibleLinkProperties" ;
    skos:definition "Properties of a flexible (demand-responsive) link in a pattern" .

netex:FlexiblePointProperties a owl:Class ;
    rdfs:label "FlexiblePointProperties" ;
    skos:definition "Properties of a flexible (demand-responsive) stop point" .

netex:FlexibleRoute a owl:Class ;
    rdfs:label "FlexibleRoute" ;
    skos:definition "Route with flexible/variable path" ;
    rdfs:subClassOf netex:Route .

netex:FrameDefaults a owl:Class ;
    rdfs:label "FrameDefaults" ;
    skos:definition "Default values for frame (timezone, locale, currency, etc.)" .

netex:GeneralFrame a owl:Class ;
    rdfs:label "GeneralFrame" ;
    skos:definition "Generic frame for arbitrary NeTEx objects" ;
    netex:containedIn netex:CompositeFrame .

netex:GroupOfOperators a owl:Class ;
    rdfs:label "GroupOfOperators" ;
    skos:definition "Grouping of operators (consortium, Verkehrsverbund, etc.)" ;
    netex:inFrame netex:ResourceFrame .

netex:GroupOfServices a owl:Class ;
    rdfs:label "GroupOfServices" ;
    skos:definition "Grouping of services for joint attributes" ;
    netex:inFrame netex:TimetableFrame .

netex:GroupOfStopPlaces a owl:Class ;
    rdfs:label "GroupOfStopPlaces" ;
    skos:definition "Grouping of related stop places (station complex, interchange hub)" ;
    netex:inFrame netex:SiteFrame .

netex:HeadwayJourneyGroup a owl:Class ;
    rdfs:label "HeadwayJourneyGroup" ;
    skos:definition "Group of journeys running at regular headway intervals" ;
    netex:inFrame netex:TimetableFrame .

netex:InfrastructureFrame a owl:Class ;
    rdfs:label "InfrastructureFrame" ;
    skos:definition "Frame for infrastructure elements (tracks, roads)" ;
    netex:containedIn netex:CompositeFrame .

netex:JourneyInterchange a owl:Class ;
    rdfs:label "JourneyInterchange" ;
    skos:definition "Planned interchange between specific journeys" ;
    netex:inFrame netex:TimetableFrame .

netex:Level a owl:Class ;
    rdfs:label "Level" ;
    skos:definition "Floor level within a station (ground, underground, mezzanine)" ;
    netex:childOf netex:StopPlace .

netex:Link a owl:Class ;
    rdfs:label "Link" ;
    skos:definition "Abstract directed connection between two points" .

netex:NavigationPath a owl:Class ;
    rdfs:label "NavigationPath" ;
    skos:definition "Pedestrian path between places within or between stops" ;
    netex:inFrame netex:SiteFrame .

netex:NoticeAssignment a owl:Class ;
    rdfs:label "NoticeAssignment" ;
    skos:definition "Assigns a Notice to a journey, stop, or pattern element" ;
    netex:inFrame netex:ServiceFrame .

netex:OccupancyView a owl:Class ;
    rdfs:label "OccupancyView" ;
    skos:definition "Expected passenger occupancy level for a journey segment" .

netex:OperationalContext a owl:Class ;
    rdfs:label "OperationalContext" ;
    skos:definition "Operational context defining vehicle type and mode for a line/journey" ;
    netex:inFrame netex:ResourceFrame .

netex:OrganisationalUnit a owl:Class ;
    rdfs:label "OrganisationalUnit" ;
    skos:definition "Subdivision of an Organisation" ;
    netex:inFrame netex:ResourceFrame .

netex:OrganisationChain a owl:Class ;
    rdfs:label "OrganisationChain" ;
    skos:definition "Chain of organisational responsibilities" .

netex:PassengerBoardingPositionAssignment a owl:Class ;
    rdfs:label "PassengerBoardingPositionAssignment" ;
    skos:definition "Assignment of a train component to a boarding position on a quay" .

netex:Point a owl:Class ;
    rdfs:label "Point" ;
    skos:definition "Abstract geographic or logical point" .

netex:PointOfInterest a owl:Class ;
    rdfs:label "PointOfInterest" ;
    skos:definition "Place of interest near a stop (attraction, facility)" ;
    netex:inFrame netex:SiteFrame .

netex:PointOnRoute a owl:Class ;
    rdfs:label "PointOnRoute" ;
    skos:definition "A point's position within a Route sequence" ;
    netex:childOf netex:Route .

netex:PointProjection a owl:Class ;
    rdfs:label "PointProjection" ;
    skos:definition "Projects a logical point onto a geographic point" .

netex:PostalAddress a owl:Class ;
    rdfs:label "PostalAddress" ;
    skos:definition "Postal address of a stop or organisation" .

netex:Presentation a owl:Class ;
    rdfs:label "Presentation" ;
    skos:definition "Visual presentation attributes (colour, font, icon)" .

netex:PropertyOfDay a owl:Class ;
    rdfs:label "PropertyOfDay" ;
    skos:definition "Properties characterizing a DayType (day of week, holiday type)" .

netex:PublicationDelivery a owl:Class ;
    rdfs:label "PublicationDelivery" ;
    skos:definition "Root envelope element for NeTEx XML document delivery" .

netex:RouteLink a owl:Class ;
    rdfs:label "RouteLink" ;
    skos:definition "Directed link between two RoutePoints" ;
    netex:inFrame netex:ServiceFrame .

netex:RoutingConstraintZone a owl:Class ;
    rdfs:label "RoutingConstraintZone" ;
    skos:definition "Zone restricting permitted boarding/alighting combinations" ;
    netex:inFrame netex:ServiceFrame .

netex:SchematicMap a owl:Class ;
    rdfs:label "SchematicMap" ;
    skos:definition "Schematic (non-geographic) map representation of a network" .

netex:ServiceFacilitySet a owl:Class ;
    rdfs:label "ServiceFacilitySet" ;
    skos:definition "Set of on-board service facilities (class, meals, wifi, etc.)" .

netex:ServiceJourneyInterchange a owl:Class ;
    rdfs:label "ServiceJourneyInterchange" ;
    skos:definition "Planned interchange between specific service journeys with guarantee/wait rules" ;
    netex:inFrame netex:TimetableFrame .

netex:ServiceJourneyPattern a owl:Class ;
    rdfs:label "ServiceJourneyPattern" ;
    skos:definition "Specialization of JourneyPattern with timing links for a service" ;
    rdfs:subClassOf netex:JourneyPattern ;
    netex:inFrame netex:ServiceFrame .

netex:ServiceLinkInJourneyPattern a owl:Class ;
    rdfs:label "ServiceLinkInJourneyPattern" ;
    skos:definition "A ServiceLink's role within a JourneyPattern sequence" ;
    netex:childOf netex:JourneyPattern .

netex:SiteFacilitySet a owl:Class ;
    rdfs:label "SiteFacilitySet" ;
    skos:definition "Set of facilities at a site (shelters, ticketing, toilets)" .

netex:StopArea a owl:Class ;
    rdfs:label "StopArea" ;
    skos:definition "Grouping area within a StopPlace containing related quays" ;
    netex:childOf netex:StopPlace .

netex:StopChain a owl:Class ;
    rdfs:label "StopChain" ;
    skos:definition "Ordered chain of stops for sequential service" .

netex:SubProfile a owl:Class ;
    rdfs:label "SubProfile" ;
    skos:definition "A profile that extends/refines another profile for a sub-domain" .

netex:TemplateServiceJourney a owl:Class ;
    rdfs:label "TemplateServiceJourney" ;
    skos:definition "Journey defined by frequency/headway rather than fixed times" ;
    rdfs:subClassOf netex:ServiceJourney ;
    netex:inFrame netex:TimetableFrame .

netex:Timeband a owl:Class ;
    rdfs:label "Timeband" ;
    skos:definition "Named time range within a day (peak, off-peak)" .

netex:TimeDemandType a owl:Class ;
    rdfs:label "TimeDemandType" ;
    skos:definition "Set of run times and dwell times between timing points for a pattern" ;
    netex:inFrame netex:ServiceFrame .

netex:TimetableChain a owl:Class ;
    rdfs:label "TimetableChain" ;
    skos:definition "Sequence of linked timetable frames for chained validity" .

netex:TimingLink a owl:Class ;
    rdfs:label "TimingLink" ;
    skos:definition "Directed link between two timing points with run time" ;
    netex:inFrame netex:ServiceFrame .

netex:TimingPoint a owl:Class ;
    rdfs:label "TimingPoint" ;
    skos:definition "Point used for timing calculations (may or may not be a stop)" ;
    netex:inFrame netex:ServiceFrame .

netex:TimingPointInJourneyPattern a owl:Class ;
    rdfs:label "TimingPointInJourneyPattern" ;
    skos:definition "A timing point's role within a journey pattern" ;
    netex:childOf netex:JourneyPattern .

netex:TrainStopAssignment a owl:Class ;
    rdfs:label "TrainStopAssignment" ;
    skos:definition "Assignment of train components to specific boarding positions at a stop" .

netex:TransferRestriction a owl:Class ;
    rdfs:label "TransferRestriction" ;
    skos:definition "Restriction on transfers at a stop or between services" .

netex:TypeOfFrame a owl:Class ;
    rdfs:label "TypeOfFrame" ;
    skos:definition "Classification/tag for a frame (profile delivery type)" .

netex:TypeOfNotice a owl:Class ;
    rdfs:label "TypeOfNotice" ;
    skos:definition "Classification of notice type" .

netex:TypeOfPlace a owl:Class ;
    rdfs:label "TypeOfPlace" ;
    skos:definition "Classification of a place (StopPlace, PointOfInterest, etc.)" .

netex:TypeOfProductCategory a owl:Class ;
    rdfs:label "TypeOfProductCategory" ;
    skos:definition "Product category for a service (InterCity, Regional, Express, etc.)" .

netex:TypeOfService a owl:Class ;
    rdfs:label "TypeOfService" ;
    skos:definition "Classification of service type (normal, express, night)" .

netex:TypeOfValue a owl:Class ;
    rdfs:label "TypeOfValue" ;
    skos:definition "Generic classification type for open enumerations" .

netex:UicOperatingPeriod a owl:Class ;
    rdfs:label "UicOperatingPeriod" ;
    skos:definition "Operating period with ValidDayBits bitmask (UIC standard)" ;
    rdfs:subClassOf netex:OperatingPeriod ;
    netex:inFrame netex:ServiceCalendarFrame .

netex:ValidityTrigger a owl:Class ;
    rdfs:label "ValidityTrigger" ;
    skos:definition "Event-based trigger for validity changes" .

netex:ValueSet a owl:Class ;
    rdfs:label "ValueSet" ;
    skos:definition "Controlled vocabulary/code list" .

netex:VehicleJourney a owl:Class ;
    rdfs:label "VehicleJourney" ;
    skos:definition "Operational vehicle journey (may differ from ServiceJourney)" ;
    skos:scopeNote "Deliberately not connected via rdfs:subClassOf or netex:specializes to ServiceJourney or DatedServiceJourney. NeTEx inherits this ambiguity from Transmodel: whether DatedServiceJourney/DatedVehicleJourney are true specializations of VehicleJourney is unresolved in CEN (issue #292). This ontology represents the gap rather than overclaiming a hierarchy that the standard itself does not formalize." ;
    netex:inFrame netex:TimetableFrame .

netex:Zone a owl:Class ;
    rdfs:label "Zone" ;
    skos:definition "Abstract geographic zone" .

