## -----------------------------------------------------------------
## NeTEx Ontology — Standard Classes & Relationships
## -----------------------------------------------------------------
## Machine-readable model of the NeTEx XML schema: classes, frames,
## relationships, XSD cardinality, SIRI bridges, and Transmodel alignment.
##
## ROLE: Base vocabulary and schema — the foundation all other files
##       import. Defines what NeTEx IS (classes, references, elements)
##       without any profile-specific constraints.
##
## LAYER STACK:
##   netex.ttl                     ← Base schema (this file)
##   └─ netex-nordic.ttl           ← Nordic Profile constraints & ordering
##      └─ netex-entur.ttl         ← Entur-specific governance & codespaces
##         └─ netex-rolling-stock.ttl ← Service sub-profile (system dependencies)
##   netex-nordic-documentation.ttl ← File paths for descriptions/tables/examples
##
## Generated: 2026-06-09
## -----------------------------------------------------------------

@prefix netex:   <https://netex-cen.eu/ontology#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix siri:    <https://siri-cen.eu/ontology#> .
@prefix tm-commons:  <https://w3id.org/transmodel/commons#> .
@prefix tm-journeys: <https://w3id.org/transmodel/journeys#> .
@prefix tm-fac:      <https://w3id.org/transmodel/facilities#> .
@prefix tm-org:      <https://w3id.org/transmodel/organisations#> .
@prefix tm-fares:    <https://w3id.org/transmodel/fares#> .

## =================================================================
## ONTOLOGY DECLARATION
## =================================================================

<https://netex-cen.eu/ontology> a owl:Ontology ;
    rdfs:label "NeTEx Base Ontology" ;
    owl:versionIRI <https://netex-cen.eu/ontology/2026-07> ;
    rdfs:comment "Machine-readable model of the NeTEx XML schema: classes, frames, relationships, XSD cardinality, SIRI bridges, and Transmodel alignment." .

## =================================================================
## META-CLASSES (ontology vocabulary)
## =================================================================

netex:Profile a owl:Class ;
    rdfs:label "Profile" ;
    skos:definition "A constrained subset of NeTEx for a specific region or use case" .

netex:DataSource a owl:Class ;
    rdfs:label "DataSource" ;
    skos:definition "Origin classification for data ownership (central registry, operator delivery, etc.)" .

## =================================================================
## CUSTOM PROPERTIES (domain-specific vocabulary)
## =================================================================
## These properties model NeTEx-specific structural relationships and
## XSD-derived metadata. They define the vocabulary that all other
## ontology files (netex-nordic.ttl, netex-entur.ttl, etc.) build upon.
##
## WHY custom properties instead of standard OWL constructs?
##   - OWL cardinality requires verbose blank-node Restrictions
##   - rdfs:domain/range applies globally; we need per-reference scoping
##   - No standard expresses XML containment hierarchy or XPath paths
##
## Profile-level constraints (excludes, requires, cardinality tightening)
## are expressed as SHACL shapes in netex-nordic.ttl and
## netex-rolling-stock.ttl — standard tooling (pySHACL, Apache Jena,
## TopBraid) can validate NeTEx data directly against them.
## -----------------------------------------------------------------

## --- Structural (XML containment hierarchy) ---

netex:contains a owl:ObjectProperty ;
    rdfs:label "contains" ;
    skos:definition "Frame or object contains these child classes as XML child elements" .

netex:containedIn a owl:ObjectProperty ;
    rdfs:label "containedIn" ;
    owl:inverseOf netex:contains ;
    skos:definition "Inverse of contains — this frame is nested within a parent frame" .

netex:childOf a owl:ObjectProperty ;
    rdfs:label "childOf" ;
    skos:definition "Object is modelled as inline child element(s) within the parent class" .

netex:inFrame a owl:ObjectProperty ;
    rdfs:label "inFrame" ;
    skos:definition "Object is a top-level member of this frame type" .

netex:specializes a owl:ObjectProperty ;
    rdfs:label "specializes" ;
    rdfs:subPropertyOf rdfs:seeAlso ;
    skos:definition "This class is a functional specialization of another (e.g. DatedServiceJourney specializes ServiceJourney)" ;
    skos:scopeNote "Deliberately NOT modelled as rdfs:subClassOf. DatedServiceJourney is not a true type-theoretic subclass of ServiceJourney — it references one rather than inheriting its identity. Using rdfs:subClassOf would allow a reasoner to wrongly conclude that a DSJ IS-A ServiceJourney, which misrepresents the NeTEx schema semantics. TemplateServiceJourney, by contrast, truly IS a ServiceJourney and correctly uses rdfs:subClassOf." .

## --- Reference metadata (per-relationship scoping) ---

netex:onClass a owl:ObjectProperty ;
    rdfs:label "onClass" ;
    skos:definition "The source class that owns this reference or element" .

netex:target a owl:ObjectProperty ;
    rdfs:label "target" ;
    skos:definition "The target class pointed to by this reference" .

netex:xsdCardinality a owl:DatatypeProperty ;
    rdfs:label "xsdCardinality" ;
    rdfs:range xsd:string ;
    skos:definition "Cardinality as defined in XSD (e.g. '0..1', '1..n'). String notation mirrors XSD minOccurs/maxOccurs." .

netex:path a owl:DatatypeProperty ;
    rdfs:label "path" ;
    rdfs:range xsd:string ;
    skos:definition "XPath-like path from the owning class to the reference element in the XML tree" .

netex:altPath a owl:DatatypeProperty ;
    rdfs:label "altPath" ;
    rdfs:range xsd:string ;
    skos:definition "Alternative XPath-like path (when multiple structural options exist)" .

## --- Element ordering ---

netex:elementOrder a owl:ObjectProperty ;
    rdfs:label "elementOrder" ;
    skos:definition "Canonical element sequence for a class (XSD-derived)" .

netex:position a owl:DatatypeProperty ;
    rdfs:label "position" ;
    rdfs:range xsd:integer ;
    skos:definition "Ordinal position within the element sequence" .

netex:element a owl:DatatypeProperty ;
    rdfs:label "element" ;
    rdfs:range xsd:string ;
    skos:definition "XML element or attribute name at this position" .

## --- Domain chains (navigational) ---

netex:step1 a owl:ObjectProperty ; rdfs:label "step1" .
netex:step2 a owl:ObjectProperty ; rdfs:label "step2" .
netex:step3 a owl:ObjectProperty ; rdfs:label "step3" .
netex:step4 a owl:ObjectProperty ; rdfs:label "step4" .
netex:step5 a owl:ObjectProperty ; rdfs:label "step5" .

## --- SIRI bridge ---

netex:referencedBySIRI a owl:ObjectProperty ;
    rdfs:label "referencedBySIRI" ;
    skos:definition "This NeTEx class is referenced by the given SIRI service via ID" .

## =================================================================
## FRAME CLASSES (Containers)
## =================================================================

netex:CompositeFrame a owl:Class ;
    rdfs:label "CompositeFrame" ;
    skos:definition "Container frame grouping multiple frames into a single delivery" ;
    netex:contains netex:ResourceFrame ,
                   netex:SiteFrame ,
                   netex:ServiceCalendarFrame ,
                   netex:ServiceFrame ,
                   netex:TimetableFrame ,
                   netex:VehicleScheduleFrame ,
                   netex:FareFrame ,
                   netex:SalesTransactionFrame ;
    netex:contains netex:Codespace .

netex:ResourceFrame a owl:Class ;
    rdfs:label "ResourceFrame" ;
    skos:definition "Organizations, vehicle types, vehicles and shared resources" ;
    netex:containedIn netex:CompositeFrame ;
    netex:contains netex:Authority ,
                   netex:Operator ,
                   netex:VehicleType ,
                   netex:Vehicle ,
                   netex:PurposeOfGrouping ,
                   netex:CompoundTrain ,
                   netex:Train .

netex:SiteFrame a owl:Class ;
    rdfs:label "SiteFrame" ;
    skos:definition "Stop places, topographic places, parking, and tariff zones" ;
    netex:containedIn netex:CompositeFrame ;
    netex:contains netex:StopPlace ,
                   netex:TopographicPlace ,
                   netex:Parking ,
                   netex:TariffZone .

netex:ServiceCalendarFrame a owl:Class ;
    rdfs:label "ServiceCalendarFrame" ;
    skos:definition "Day types, operating periods, and calendar assignments" ;
    netex:containedIn netex:CompositeFrame ;
    netex:contains netex:ServiceCalendar ,
                   netex:DayType ,
                   netex:DayTypeAssignment ,
                   netex:OperatingPeriod ,
                   netex:OperatingDay .

netex:ServiceFrame a owl:Class ;
    rdfs:label "ServiceFrame" ;
    skos:definition "Lines, routes, journey patterns, stop points, and assignments" ;
    netex:containedIn netex:CompositeFrame ;
    netex:contains netex:Line ,
                   netex:Route ,
                   netex:JourneyPattern ,
                   netex:ScheduledStopPoint ,
                   netex:PassengerStopAssignment ,
                   netex:DestinationDisplay ,
                   netex:GroupOfLines ,
                   netex:Notice ,
                   netex:FlexibleServiceProperties ,
                   netex:RoutePoint ,
                   netex:ServiceLink ,
                   netex:SiteConnection .

netex:TimetableFrame a owl:Class ;
    rdfs:label "TimetableFrame" ;
    skos:definition "Service journeys, dated journeys, and interchange rules" ;
    netex:containedIn netex:CompositeFrame ;
    netex:contains netex:ServiceJourney ,
                   netex:DatedServiceJourney ,
                   netex:Interchange ,
                   netex:TrainNumber .

netex:VehicleScheduleFrame a owl:Class ;
    rdfs:label "VehicleScheduleFrame" ;
    skos:definition "Vehicle blocks and scheduling assignments" ;
    netex:containedIn netex:CompositeFrame ;
    netex:contains netex:TrainBlock .

netex:FareFrame a owl:Class ;
    rdfs:label "FareFrame" ;
    skos:definition "Fares, tariffs, fare products, and sales offer packages" ;
    netex:containedIn netex:CompositeFrame ;
    netex:contains netex:FareZone .

netex:SalesTransactionFrame a owl:Class ;
    rdfs:label "SalesTransactionFrame" ;
    skos:definition "Sales transaction data and fare contracts" ;
    netex:containedIn netex:CompositeFrame ;
    netex:contains netex:FareContract .

## =================================================================
## OBJECT CLASSES
## =================================================================

## -----------------------------------------------------------------
## ResourceFrame objects
## -----------------------------------------------------------------

netex:Organisation a owl:Class ;
    rdfs:label "Organisation" ;
    skos:definition "Abstract superclass for all organisational entities (Authority, Operator, etc.)" ;
    netex:inFrame netex:ResourceFrame .

netex:Authority a owl:Class ;
    rdfs:label "Authority" ;
    skos:definition "Transit authority — the public body responsible for organizing transport" ;
    rdfs:subClassOf netex:Organisation ;
    netex:inFrame netex:ResourceFrame .

netex:Operator a owl:Class ;
    rdfs:label "Operator" ;
    skos:definition "Transport operator — the company running the services" ;
    rdfs:subClassOf netex:Organisation ;
    netex:inFrame netex:ResourceFrame .

netex:VehicleType a owl:Class ;
    rdfs:label "VehicleType" ;
    skos:definition "Vehicle classification with capacity and propulsion characteristics" ;
    netex:inFrame netex:ResourceFrame .

netex:Vehicle a owl:Class ;
    rdfs:label "Vehicle" ;
    skos:definition "Individual rolling stock unit assigned to an operator" ;
    netex:inFrame netex:ResourceFrame .

netex:PurposeOfGrouping a owl:Class ;
    rdfs:label "PurposeOfGrouping" ;
    skos:definition "Classification of why objects are grouped together" ;
    netex:inFrame netex:ResourceFrame .

netex:ResponsibilitySet a owl:Class ;
    rdfs:label "ResponsibilitySet" ;
    skos:definition "Set of responsibility role assignments linking organizations to domains" ;
    netex:inFrame netex:ResourceFrame .

netex:Contract a owl:Class ;
    rdfs:label "Contract" ;
    skos:definition "Agreement between authority and operator for service provision" ;
    netex:inFrame netex:ResourceFrame .

netex:CompoundTrain a owl:Class ;
    rdfs:label "CompoundTrain" ;
    skos:definition "Composed rolling stock formation consisting of multiple Train units coupled together" ;
    netex:inFrame netex:ResourceFrame .

netex:TrainInCompoundTrain a owl:Class ;
    rdfs:label "TrainInCompoundTrain" ;
    skos:definition "A Train's role within a CompoundTrain (order, operational orientation)" ;
    netex:childOf netex:CompoundTrain .

netex:Train a owl:Class ;
    rdfs:label "Train" ;
    skos:definition "A single train unit with its components (coaches, wagons)" ;
    netex:inFrame netex:ResourceFrame .

netex:TrainComponent a owl:Class ;
    rdfs:label "TrainComponent" ;
    skos:definition "A TrainElement's role within a Train (order, label, orientation)" ;
    netex:childOf netex:Train .

netex:TrainElement a owl:Class ;
    rdfs:label "TrainElement" ;
    skos:definition "Individual coach or wagon unit within a Train, carrying capacity and equipment details" ;
    netex:childOf netex:Train .

## -----------------------------------------------------------------
## SiteFrame objects
## -----------------------------------------------------------------

netex:StopPlace a owl:Class ;
    rdfs:label "StopPlace" ;
    skos:definition "Physical stop location containing one or more quays" ;
    netex:inFrame netex:SiteFrame .

netex:Quay a owl:Class ;
    rdfs:label "Quay" ;
    skos:definition "Boarding/alighting point within a StopPlace" ;
    netex:childOf netex:StopPlace .

netex:TopographicPlace a owl:Class ;
    rdfs:label "TopographicPlace" ;
    skos:definition "Named geographic area (city, municipality, county)" ;
    netex:inFrame netex:SiteFrame .

netex:Parking a owl:Class ;
    rdfs:label "Parking" ;
    skos:definition "Parking facility, typically associated with a StopPlace" ;
    netex:inFrame netex:SiteFrame .

netex:TariffZone a owl:Class ;
    rdfs:label "TariffZone" ;
    skos:definition "Geographic zone used for fare calculation" ;
    netex:inFrame netex:SiteFrame .

netex:FareZone a owl:Class ;
    rdfs:label "FareZone" ;
    skos:definition "Zone defining fare boundaries, may contain scheduled stop points" ;
    netex:inFrame netex:FareFrame .

## -----------------------------------------------------------------
## Equipment objects (children of StopPlace/Quay)
## -----------------------------------------------------------------

netex:ShelterEquipment a owl:Class ;
    rdfs:label "ShelterEquipment" ;
    skos:definition "Waiting shelter at a stop" ;
    netex:childOf netex:StopPlace , netex:Quay .

netex:WaitingRoomEquipment a owl:Class ;
    rdfs:label "WaitingRoomEquipment" ;
    skos:definition "Waiting room facility at a stop" ;
    netex:childOf netex:StopPlace , netex:Quay .

netex:SanitaryEquipment a owl:Class ;
    rdfs:label "SanitaryEquipment" ;
    skos:definition "Sanitary facilities at a stop" ;
    netex:childOf netex:StopPlace , netex:Quay .

netex:TicketingEquipment a owl:Class ;
    rdfs:label "TicketingEquipment" ;
    skos:definition "Ticketing machines and validation equipment" ;
    netex:childOf netex:StopPlace , netex:Quay .

## -----------------------------------------------------------------
## ServiceCalendarFrame objects
## -----------------------------------------------------------------

netex:ServiceCalendar a owl:Class ;
    rdfs:label "ServiceCalendar" ;
    skos:definition "Logical container with shared validity period for calendar-related elements" ;
    netex:inFrame netex:ServiceCalendarFrame .

netex:DayType a owl:Class ;
    rdfs:label "DayType" ;
    skos:definition "Abstract day classification (weekday, holiday, etc.)" ;
    netex:inFrame netex:ServiceCalendarFrame .

netex:DayTypeAssignment a owl:Class ;
    rdfs:label "DayTypeAssignment" ;
    skos:definition "Binds a DayType to a specific date or OperatingPeriod" ;
    netex:inFrame netex:ServiceCalendarFrame .

netex:OperatingPeriod a owl:Class ;
    rdfs:label "OperatingPeriod" ;
    skos:definition "Date range (FromDate–ToDate) for recurring service" ;
    netex:inFrame netex:ServiceCalendarFrame .

netex:OperatingDay a owl:Class ;
    rdfs:label "OperatingDay" ;
    skos:definition "Specific calendar date for DatedServiceJourney instances" ;
    netex:inFrame netex:ServiceCalendarFrame .

## -----------------------------------------------------------------
## ServiceFrame objects
## -----------------------------------------------------------------

netex:Line a owl:Class ;
    rdfs:label "Line" ;
    skos:definition "Public transport service line grouping routes and journeys" ;
    netex:inFrame netex:ServiceFrame .

netex:GroupOfLines a owl:Class ;
    rdfs:label "GroupOfLines" ;
    skos:definition "Logical grouping of lines (e.g. by area or mode)" ;
    netex:inFrame netex:ServiceFrame .

netex:Route a owl:Class ;
    rdfs:label "Route" ;
    skos:definition "Ordered sequence of points defining a path for a line" ;
    netex:inFrame netex:ServiceFrame .

netex:JourneyPattern a owl:Class ;
    rdfs:label "JourneyPattern" ;
    skos:definition "Ordered sequence of stop points defining where a journey calls" ;
    netex:inFrame netex:ServiceFrame .

netex:StopPointInJourneyPattern a owl:Class ;
    rdfs:label "StopPointInJourneyPattern" ;
    skos:definition "A stop point's role within a journey pattern (order, boarding rules)" ;
    netex:childOf netex:JourneyPattern .

netex:ScheduledStopPoint a owl:Class ;
    rdfs:label "ScheduledStopPoint" ;
    skos:definition "Logical stop point in the timetable, linked to physical StopPlace via assignment" ;
    netex:inFrame netex:ServiceFrame .

netex:PassengerStopAssignment a owl:Class ;
    rdfs:label "PassengerStopAssignment" ;
    skos:definition "Bridge linking a logical ScheduledStopPoint to a physical StopPlace/Quay" ;
    netex:inFrame netex:ServiceFrame .

netex:DestinationDisplay a owl:Class ;
    rdfs:label "DestinationDisplay" ;
    skos:definition "Text shown to passengers on displays and signs" ;
    netex:inFrame netex:ServiceFrame .

netex:Notice a owl:Class ;
    rdfs:label "Notice" ;
    skos:definition "Informational text attached to journeys or stop points" ;
    netex:inFrame netex:ServiceFrame .

netex:FlexibleServiceProperties a owl:Class ;
    rdfs:label "FlexibleServiceProperties" ;
    skos:definition "Booking and flexibility rules for demand-responsive transport" ;
    netex:inFrame netex:ServiceFrame .

netex:LinkSequenceProjection a owl:Class ;
    rdfs:label "LinkSequenceProjection" ;
    skos:definition "GML geometry projecting a route or link onto a map" ;
    netex:inFrame netex:ServiceFrame .

netex:RoutePoint a owl:Class ;
    rdfs:label "RoutePoint" ;
    skos:definition "A point that identifies a location in a Route, used as building block for PointOnRoute" ;
    netex:inFrame netex:ServiceFrame .

netex:ServiceLink a owl:Class ;
    rdfs:label "ServiceLink" ;
    skos:definition "Directed link between two ScheduledStopPoints, carrying distance and optional GML projection" ;
    netex:inFrame netex:ServiceFrame .

netex:SiteConnection a owl:Class ;
    rdfs:label "SiteConnection" ;
    skos:definition "Transfer connection between two stop places with walking duration" ;
    netex:inFrame netex:ServiceFrame .

## -----------------------------------------------------------------
## TimetableFrame objects
## -----------------------------------------------------------------

netex:ServiceJourney a owl:Class ;
    rdfs:label "ServiceJourney" ;
    skos:definition "A planned trip template in the timetable, reusable across dates" ;
    netex:inFrame netex:TimetableFrame .

netex:TimetabledPassingTime a owl:Class ;
    rdfs:label "TimetabledPassingTime" ;
    skos:definition "Arrival/departure times at a specific stop within a ServiceJourney" ;
    netex:childOf netex:ServiceJourney .

netex:DatedServiceJourney a owl:Class ;
    rdfs:label "DatedServiceJourney" ;
    skos:definition "A concrete journey instance on a specific date, possibly with alterations" ;
    netex:inFrame netex:TimetableFrame ;
    netex:specializes netex:ServiceJourney .

netex:Interchange a owl:Class ;
    rdfs:label "Interchange" ;
    skos:definition "Planned transfer between two service journeys at stop points" ;
    netex:inFrame netex:TimetableFrame .

netex:TrainNumber a owl:Class ;
    rdfs:label "TrainNumber" ;
    skos:definition "Railway-specific train service number, referenced via JourneyPart" ;
    netex:inFrame netex:TimetableFrame .

netex:JourneyPart a owl:Class ;
    rdfs:label "JourneyPart" ;
    skos:definition "A segment of a ServiceJourney with its own train composition and facilities" ;
    netex:childOf netex:ServiceJourney .

## -----------------------------------------------------------------
## VehicleScheduleFrame objects
## -----------------------------------------------------------------

netex:TrainBlock a owl:Class ;
    rdfs:label "TrainBlock" ;
    skos:definition "Block of journeys assigned to a single vehicle" ;
    netex:inFrame netex:VehicleScheduleFrame .

netex:TrainBlockPart a owl:Class ;
    rdfs:label "TrainBlockPart" ;
    skos:definition "A segment of a TrainBlock linking a JourneyPart to a CompoundTrain" ;
    netex:childOf netex:TrainBlock .

## -----------------------------------------------------------------
## SalesTransactionFrame objects
## -----------------------------------------------------------------

netex:FareContract a owl:Class ;
    rdfs:label "FareContract" ;
    skos:definition "A fare contract with entries representing purchased products" ;
    netex:inFrame netex:SalesTransactionFrame .

## -----------------------------------------------------------------
## Metadata objects (not frame-specific)
## -----------------------------------------------------------------

netex:AlternativeName a owl:Class ;
    rdfs:label "AlternativeName" ;
    skos:definition "Alternative name for any object (alias, translation, etc.)" .

netex:AlternativeText a owl:Class ;
    rdfs:label "AlternativeText" ;
    skos:definition "Alternative text representation for multilingual content" .

netex:Codespace a owl:Class ;
    rdfs:label "Codespace" ;
    skos:definition "XML namespace mapping (Xmlns ↔ XmlnsUrl) used in ID prefixes" .

netex:Network a owl:Class ;
    rdfs:label "Network" ;
    skos:definition "Top-level grouping of lines for an authority/operator" ;
    netex:inFrame netex:ServiceFrame .

## =================================================================
## RELATIONSHIPS — NAMED REFERENCES
## =================================================================
## Each reference is a first-class resource: netex:ClassName_PropertyName.
## This enables referential integrity between base and profile layers.
## -----------------------------------------------------------------

netex:Reference a owl:Class ;
    rdfs:label "Reference" ;
    skos:definition "A typed reference property from one NeTEx class to another" .

netex:Composition a owl:Class ;
    rdfs:label "Composition" ;
    skos:definition "A containment relationship (inline child elements)" .

## --- ResourceFrame relationships ---

netex:Operator_AuthorityRef a netex:Reference ;
    rdfs:label "Operator → AuthorityRef" ;
    netex:onClass netex:Operator ;
    netex:target netex:Authority ;
    netex:xsdCardinality "0..1" .

netex:Vehicle_OperatorRef a netex:Reference ;
    rdfs:label "Vehicle → OperatorRef" ;
    netex:onClass netex:Vehicle ;
    netex:target netex:Operator ;
    netex:xsdCardinality "0..1" .

netex:Vehicle_VehicleTypeRef a netex:Reference ;
    rdfs:label "Vehicle → VehicleTypeRef" ;
    netex:onClass netex:Vehicle ;
    netex:target netex:VehicleType ;
    netex:xsdCardinality "0..1" .

netex:ResponsibilitySet_ResponsibleOrganisationRef a netex:Reference ;
    rdfs:label "ResponsibilitySet → ResponsibleOrganisationRef" ;
    netex:onClass netex:ResponsibilitySet ;
    netex:target netex:Authority ;
    netex:xsdCardinality "0..1" ;
    netex:path "roles/ResponsibilityRoleAssignment/ResponsibleOrganisationRef" .

netex:ResponsibilitySet_ContractRef a netex:Reference ;
    rdfs:label "ResponsibilitySet → ContractRef" ;
    netex:onClass netex:ResponsibilitySet ;
    netex:target netex:Contract ;
    netex:xsdCardinality "0..1" ;
    netex:path "roles/ResponsibilityRoleAssignment/AssociatedContract/ContractRef" .

netex:Contract_OrganisationRef_contractees a netex:Reference ;
    rdfs:label "Contract → OrganisationRef (contractees)" ;
    netex:onClass netex:Contract ;
    netex:target netex:Authority ;
    netex:xsdCardinality "0..n" ;
    netex:path "contractees/OrganisationRef" .

netex:Contract_OrganisationRef_contractors a netex:Reference ;
    rdfs:label "Contract → OrganisationRef (contractors)" ;
    netex:onClass netex:Contract ;
    netex:target netex:Operator ;
    netex:xsdCardinality "0..n" ;
    netex:path "contractors/OrganisationRef" .

## --- SiteFrame relationships ---

netex:StopPlace_TopographicPlaceRef a netex:Reference ;
    rdfs:label "StopPlace → TopographicPlaceRef" ;
    netex:onClass netex:StopPlace ;
    netex:target netex:TopographicPlace ;
    netex:xsdCardinality "0..1" .

netex:StopPlace_ParentSiteRef a netex:Reference ;
    rdfs:label "StopPlace → ParentSiteRef" ;
    netex:onClass netex:StopPlace ;
    netex:target netex:StopPlace ;
    netex:xsdCardinality "0..1" .

netex:StopPlace_TariffZoneRef a netex:Reference ;
    rdfs:label "StopPlace → TariffZoneRef" ;
    netex:onClass netex:StopPlace ;
    netex:target netex:TariffZone ;
    netex:xsdCardinality "0..n" .

netex:StopPlace_quays a netex:Composition ;
    rdfs:label "StopPlace → quays" ;
    netex:onClass netex:StopPlace ;
    netex:target netex:Quay ;
    netex:xsdCardinality "0..n" .

netex:TopographicPlace_ParentTopographicPlaceRef a netex:Reference ;
    rdfs:label "TopographicPlace → ParentTopographicPlaceRef" ;
    netex:onClass netex:TopographicPlace ;
    netex:target netex:TopographicPlace ;
    netex:xsdCardinality "0..1" .

netex:Parking_ParentSiteRef a netex:Reference ;
    rdfs:label "Parking → ParentSiteRef" ;
    netex:onClass netex:Parking ;
    netex:target netex:StopPlace ;
    netex:xsdCardinality "0..1" .

netex:FareZone_ScheduledStopPointRef a netex:Reference ;
    rdfs:label "FareZone → ScheduledStopPointRef" ;
    netex:onClass netex:FareZone ;
    netex:target netex:ScheduledStopPoint ;
    netex:xsdCardinality "0..n" ;
    netex:path "members/ScheduledStopPointRef" .

## --- ServiceCalendarFrame relationships ---

