## -----------------------------------------------------------------
## Nordic NeTEx Profile Ontology
## -----------------------------------------------------------------
## ROLE: Defines what the Nordic Profile ALLOWS, REQUIRES, and EXCLUDES
##       beyond the XSD schema. Cardinality tightening, element ordering,
##       and navigational domain chains.
##
## This is the shared Nordic agreement (NO, SE, FI, DK) — constraints
## that go beyond what XSD expresses but are mandatory for interoperability.
##
## Imports: netex.ttl (base NeTEx classes and relationships)
##
## Generated: 2026-06-09
## -----------------------------------------------------------------

@prefix netex:   <https://netex-cen.eu/ontology#> .
@prefix profile: <https://netex-cen.eu/profile#> .
@prefix sh:      <http://www.w3.org/ns/shacl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .

## --- Import base NeTEx ontology ---
<https://netex-cen.eu/profile/nordic> a owl:Ontology ;
    owl:imports <https://netex-cen.eu/ontology> .

## =================================================================
## PROFILE DEFINITION
## =================================================================

profile:NP a netex:Profile ;
    rdfs:label "Nordic Profile" ;
    skos:notation "NP" ;
    skos:definition "Shared NeTEx profile for Norway, Sweden, Finland and Denmark" ;
    netex:dataConfidence [
        netex:level "HIGH" ;
        netex:basis "Multiple production datasets from Entur (NO), validated element ordering against live exports. Profile maintained by cross-Nordic editorial team." ;
        netex:datasets "Entur aggregated NeTEx (VYG), per-line exports, Entur stop register" ;
        netex:lastValidated "2026-06"
    ] .

## =================================================================
## PROFILE CONSTRAINTS — SHACL SHAPES
## =================================================================
## NP-specific exclusions, allowances, and cardinality tightening.
## Expressed as SHACL NodeShapes for validation with standard tooling
## (pySHACL, Apache Jena, TopBraid).
##
## sh:path references point to named Reference/Element resources
## defined in netex.ttl, enabling traceability between constraints
## and the base schema vocabulary.
##
## Shape naming: profile:NP_{ClassName}Shape
## -----------------------------------------------------------------

## --- StopPlace ---

profile:NP_StopPlaceShape a sh:NodeShape ;
    sh:targetClass netex:StopPlace ;
    rdfs:label "StopPlace — NP constraints" ;
    ## Excluded
    sh:property [
        sh:path netex:StopPlace_ParentSiteRef ;
        sh:maxCount 0 ;
        sh:name "ParentSiteRef" ;
        sh:description "Not used in NP — stop hierarchy managed by central registry"
    ] , [
        sh:path netex:StopPlace_TariffZoneRef ;
        sh:maxCount 0 ;
        sh:name "TariffZoneRef" ;
        sh:description "Not used in NP"
    ] ;
    ## Allowed (0..1)
    sh:property [
        sh:path netex:StopPlace_TopographicPlaceRef ;
        sh:maxCount 1 ;
        sh:name "TopographicPlaceRef"
    ] , [
        sh:path netex:StopPlace_ValidBetween ;
        sh:maxCount 1 ;
        sh:name "ValidBetween"
    ] , [
        sh:path netex:StopPlace_AccessibilityAssessment ;
        sh:maxCount 1 ;
        sh:name "AccessibilityAssessment"
    ] .

## --- Quay ---

profile:NP_QuayShape a sh:NodeShape ;
    sh:targetClass netex:Quay ;
    rdfs:label "Quay — NP constraints" ;
    sh:property [
        sh:path netex:Quay_AccessibilityAssessment ;
        sh:maxCount 1 ;
        sh:name "AccessibilityAssessment"
    ] , [
        sh:path netex:Quay_boardingPositions ;
        sh:maxCount 1 ;
        sh:name "boardingPositions"
    ] .

## --- Line ---

profile:NP_LineShape a sh:NodeShape ;
    sh:targetClass netex:Line ;
    rdfs:label "Line — NP constraints" ;
    sh:property [
        sh:path netex:Line_RepresentedByGroupRef ;
        sh:maxCount 1 ;
        sh:name "RepresentedByGroupRef"
    ] , [
        sh:path netex:Line_TransportSubmode ;
        sh:maxCount 1 ;
        sh:name "TransportSubmode"
    ] , [
        sh:path netex:Line_PublicCode ;
        sh:maxCount 1 ;
        sh:name "PublicCode"
    ] , [
        sh:path netex:Line_PrivateCode ;
        sh:maxCount 1 ;
        sh:name "PrivateCode"
    ] .

## --- ServiceJourney ---

profile:NP_ServiceJourneyShape a sh:NodeShape ;
    sh:targetClass netex:ServiceJourney ;
    rdfs:label "ServiceJourney — NP constraints" ;
    ## Excluded
    sh:property [
        sh:path netex:ServiceJourney_FlexibleLineRef ;
        sh:maxCount 0 ;
        sh:name "FlexibleLineRef" ;
        sh:description "Not used in NP — use Line with FlexibleServiceProperties"
    ] , [
        sh:path netex:ServiceJourney_BlockRef ;
        sh:maxCount 0 ;
        sh:name "BlockRef" ;
        sh:description "Not used in NP — block assignment via DatedServiceJourney"
    ] .

## --- JourneyPattern ---

profile:NP_JourneyPatternShape a sh:NodeShape ;
    sh:targetClass netex:JourneyPattern ;
    rdfs:label "JourneyPattern — NP constraints" ;
    ## Required (tightened from XSD 0..1)
    sh:property [
        sh:path netex:JourneyPattern_RouteRef ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:class netex:Route ;
        sh:name "RouteRef" ;
        sh:description "XSD allows 0..1, NP mandates 1..1"
    ] .

## --- Vehicle ---

profile:NP_VehicleShape a sh:NodeShape ;
    sh:targetClass netex:Vehicle ;
    rdfs:label "Vehicle — NP constraints" ;
    ## Required (tightened from XSD 0..1)
    sh:property [
        sh:path netex:Vehicle_VehicleTypeRef ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:class netex:VehicleType ;
        sh:name "VehicleTypeRef" ;
        sh:description "XSD allows 0..1, NP mandates 1..1"
    ] .

## --- Authority ---

profile:NP_AuthorityShape a sh:NodeShape ;
    sh:targetClass netex:Authority ;
    rdfs:label "Authority — NP constraints" ;
    sh:property [
        sh:path netex:Authority_Name ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:name "Name" ;
        sh:description "XSD allows 0..1, NP mandates 1..1"
    ] .

## --- Operator ---

profile:NP_OperatorShape a sh:NodeShape ;
    sh:targetClass netex:Operator ;
    rdfs:label "Operator — NP constraints" ;
    sh:property [
        sh:path netex:Operator_Name ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:name "Name" ;
        sh:description "XSD allows 0..1, NP mandates 1..1"
    ] .

## --- VehicleType ---

profile:NP_VehicleTypeShape a sh:NodeShape ;
    sh:targetClass netex:VehicleType ;
    rdfs:label "VehicleType — NP constraints" ;
    sh:property [
        sh:path netex:VehicleType_Name ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:name "Name" ;
        sh:description "XSD allows 0..1, NP mandates 1..1"
    ] .

## --- FareZone ---

profile:NP_FareZoneShape a sh:NodeShape ;
    sh:targetClass netex:FareZone ;
    rdfs:label "FareZone — NP constraints" ;
    sh:property [
        sh:path netex:FareZone_Name ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:name "Name" ;
        sh:description "XSD allows 0..1, NP mandates 1..1"
    ] .

## --- Interchange ---

profile:NP_InterchangeShape a sh:NodeShape ;
    sh:targetClass netex:Interchange ;
    rdfs:label "Interchange — NP constraints" ;
    sh:property [
        sh:path netex:Interchange_FromPointRef ;
        sh:maxCount 1 ;
        sh:name "FromPointRef"
    ] , [
        sh:path netex:Interchange_ToPointRef ;
        sh:maxCount 1 ;
        sh:name "ToPointRef"
    ] .

## --- DatedServiceJourney ---

profile:NP_DatedServiceJourneyShape a sh:NodeShape ;
    sh:targetClass netex:DatedServiceJourney ;
    rdfs:label "DatedServiceJourney — NP constraints" ;
    sh:property [
        sh:path netex:DatedServiceJourney_ServiceJourneyRef ;
        sh:name "ServiceJourneyRef" ;
        sh:description "Reference to the template ServiceJourney this dated instance realizes" ;
        sh:minCount 1 ;
        sh:maxCount 1
    ] , [
        sh:path netex:DatedServiceJourney_OperatingDayRef ;
        sh:name "OperatingDayRef" ;
        sh:description "The specific operating day this journey runs on" ;
        sh:minCount 1 ;
        sh:maxCount 1
    ] , [
        sh:path netex:DatedServiceJourney_DatedVehicleJourneyRef ;
        sh:name "DatedVehicleJourneyRef" ;
        sh:description "Deviation/replacement tracking — allowed in NP"
    ] , [
        sh:path netex:DatedServiceJourney_ServiceAlteration ;
        sh:name "ServiceAlteration" ;
        sh:description "Alteration status code when journey deviates from plan" ;
        sh:maxCount 1 ;
        sh:in ( "planned" "cancellation" "replaced" "extraJourney" )
    ] .

## =================================================================
## ELEMENT ORDERING (XSD-derived)
## =================================================================
## Canonical element sequence per class, derived from XSD type
## hierarchy. Tables, descriptions, and generators should follow
## this order. Attributes (@id, @version, @order) are listed first
## by convention — XML attributes have no sequence constraint.
## Only elements documented in the profile Tables are listed.
## -----------------------------------------------------------------

netex:ServiceJourney netex:elementOrder [
    netex:position 1 ; netex:element "@id"
] , [
    netex:position 2 ; netex:element "@version"
] , [
    netex:position 3 ; netex:element "keyList"
] , [
    netex:position 4 ; netex:element "Name"
] , [
    netex:position 5 ; netex:element "PrivateCode"
] , [
    netex:position 6 ; netex:element "Description"
] , [
    netex:position 7 ; netex:element "TransportMode"
] , [
    netex:position 8 ; netex:element "TransportSubmode"
] , [
    ## XSD: ServiceTimeGroup — DepartureTime before dayTypes
    netex:position 9 ; netex:element "DepartureTime"
] , [
    netex:position 10 ; netex:element "DepartureDayOffset"
] , [
    netex:position 11 ; netex:element "dayTypes"
] , [
    netex:position 12 ; netex:element "JourneyPatternRef"
] , [
    ## XSD: ServiceJourneyPatternRef is the specialised alternative to JourneyPatternRef
    netex:position 12 ; netex:element "ServiceJourneyPatternRef"
] , [
    netex:position 13 ; netex:element "VehicleTypeRef"
] , [
    netex:position 14 ; netex:element "BlockRef"
] , [
    netex:position 15 ; netex:element "OperatorRef"
] , [
    netex:position 16 ; netex:element "LineRef"
] , [
    netex:position 17 ; netex:element "FlexibleLineRef"
] , [
    netex:position 18 ; netex:element "passingTimes"
] , [
    netex:position 19 ; netex:element "parts"
] .

netex:Operator netex:elementOrder [
    netex:position 1 ; netex:element "@id"
] , [
    netex:position 2 ; netex:element "@version"
] , [
    netex:position 3 ; netex:element "CompanyNumber"
] , [
    netex:position 4 ; netex:element "Name"
] , [
    netex:position 5 ; netex:element "ShortName"
] , [
    netex:position 6 ; netex:element "LegalName"
] , [
    netex:position 7 ; netex:element "ContactDetails"
] , [
    netex:position 8 ; netex:element "OrganisationType"
] , [
    netex:position 9 ; netex:element "CountryRef"
] , [
    netex:position 10 ; netex:element "PrimaryMode"
] , [
    netex:position 11 ; netex:element "CustomerServiceContactDetails"
] .

netex:StopPlace netex:elementOrder [
    netex:position 1 ; netex:element "@id"
] , [
    netex:position 2 ; netex:element "@version"
] , [
    netex:position 3 ; netex:element "ValidBetween"
] , [
    netex:position 4 ; netex:element "keyList"
] , [
    netex:position 5 ; netex:element "Name"
] , [
    netex:position 6 ; netex:element "Centroid"
] , [
    netex:position 7 ; netex:element "AccessibilityAssessment"
] , [
    netex:position 8 ; netex:element "TopographicPlaceRef"
] , [
    netex:position 9 ; netex:element "ParentSiteRef"
] , [
    netex:position 10 ; netex:element "TransportMode"
] , [
    netex:position 11 ; netex:element "StopPlaceType"
] , [
    netex:position 12 ; netex:element "Weighting"
] , [
    netex:position 13 ; netex:element "quays"
] .

netex:Line netex:elementOrder [
    netex:position 1 ; netex:element "@id"
] , [
    netex:position 2 ; netex:element "@version"
] , [
    netex:position 3 ; netex:element "Name"
] , [
    ## XSD: DataManagedObjectGroup — ShortName follows Name
    netex:position 4 ; netex:element "ShortName"
] , [
    netex:position 5 ; netex:element "TransportMode"
] , [
    netex:position 6 ; netex:element "TransportSubmode"
] , [
    netex:position 7 ; netex:element "PublicCode"
] , [
    netex:position 8 ; netex:element "PrivateCode"
] , [
    ## XSD: LinePropertiesGroup — AuthorityRef before OperatorRef
    netex:position 9 ; netex:element "AuthorityRef"
] , [
    netex:position 10 ; netex:element "OperatorRef"
] , [
    netex:position 11 ; netex:element "Monitored"
] , [
    netex:position 12 ; netex:element "RepresentedByGroupRef"
] , [
    netex:position 13 ; netex:element "Presentation"
] .

netex:Route netex:elementOrder [
    netex:position 1 ; netex:element "@id"
] , [
    netex:position 2 ; netex:element "@version"
] , [
    netex:position 3 ; netex:element "Name"
] , [
    netex:position 4 ; netex:element "ShortName"
] , [
    netex:position 5 ; netex:element "Description"
] , [
    netex:position 6 ; netex:element "LineRef"
] , [
    netex:position 7 ; netex:element "DirectionType"
] , [
    netex:position 8 ; netex:element "pointsInSequence"
] , [
    netex:position 9 ; netex:element "InverseRouteRef"
] .

netex:JourneyPattern netex:elementOrder [
    netex:position 1 ; netex:element "@id"
] , [
    netex:position 2 ; netex:element "@version"
] , [
    netex:position 3 ; netex:element "Name"
] , [
    netex:position 4 ; netex:element "RouteRef"
] , [
    netex:position 5 ; netex:element "pointsInSequence"
] , [
    netex:position 6 ; netex:element "linksInSequence"
] .

netex:DatedServiceJourney netex:elementOrder [
    netex:position 1 ; netex:element "@id"
] , [
    netex:position 2 ; netex:element "@version"
] , [
    netex:position 3 ; netex:element "ServiceAlteration"
] , [
    netex:position 4 ; netex:element "BlockRef"
] , [
    netex:position 5 ; netex:element "ServiceJourneyRef"
] , [
    netex:position 6 ; netex:element "replacedJourneys"
] , [
    netex:position 7 ; netex:element "OperatingDayRef"
] .

netex:DayType netex:elementOrder [
    netex:position 1 ; netex:element "@id"
] , [
    netex:position 2 ; netex:element "@version"
] , [
    netex:position 3 ; netex:element "Name"
] , [
    netex:position 4 ; netex:element "properties"
] .

netex:ScheduledStopPoint netex:elementOrder [
    netex:position 1 ; netex:element "@id"
] , [
    netex:position 2 ; netex:element "@version"
] , [
    netex:position 3 ; netex:element "ValidBetween"
] , [
    netex:position 4 ; netex:element "Name"
] , [
    netex:position 5 ; netex:element "TimingPointStatus"
] .

netex:PassengerStopAssignment netex:elementOrder [
    netex:position 1 ; netex:element "@id"
] , [
    netex:position 2 ; netex:element "@version"
] , [
    netex:position 3 ; netex:element "@order"
] , [
    netex:position 4 ; netex:element "ValidBetween"
] , [
    netex:position 5 ; netex:element "ScheduledStopPointRef"
] , [
    netex:position 6 ; netex:element "StopPlaceRef"
] , [
    netex:position 7 ; netex:element "QuayRef"
] .

netex:DestinationDisplay netex:elementOrder [
    netex:position 1 ; netex:element "@id"
] , [
    netex:position 2 ; netex:element "@version"
] , [
    netex:position 3 ; netex:element "Name"
] , [
    netex:position 4 ; netex:element "SideText"
] , [
    netex:position 5 ; netex:element "FrontText"
] , [
    netex:position 6 ; netex:element "vias"
] .

## =================================================================
## DOMAIN CHAINS (navigational shortcuts)
## =================================================================

netex:TimetableChain rdfs:comment """
    Line → Route → JourneyPattern → ServiceJourney → DatedServiceJourney
    The core modelling chain: from abstract line identity
    through physical route, stop sequence, timed trip template,
    to a concrete instance on a specific date.
""" ;
    netex:step1 netex:Line ;
    netex:step2 netex:Route ;
    netex:step3 netex:JourneyPattern ;
    netex:step4 netex:ServiceJourney ;
    netex:step5 netex:DatedServiceJourney .

netex:StopChain rdfs:comment """
    ScheduledStopPoint → PassengerStopAssignment → StopPlace → Quay
    The logical-to-physical stop bridge.
""" ;
    netex:step1 netex:ScheduledStopPoint ;
    netex:step2 netex:PassengerStopAssignment ;
    netex:step3 netex:StopPlace ;
    netex:step4 netex:Quay .

netex:CalendarChain rdfs:comment """
    DayType → DayTypeAssignment → OperatingPeriod / Date
    How services are bound to dates.
""" ;
    netex:step1 netex:DayType ;
    netex:step2 netex:DayTypeAssignment ;
    netex:step3 netex:OperatingPeriod .

netex:OrganisationChain rdfs:comment """
    Authority → Contract → Operator → ResponsibilitySet
    Organisational governance and responsibility.
""" ;
    netex:step1 netex:Authority ;
    netex:step2 netex:Contract ;
    netex:step3 netex:Operator ;
    netex:step4 netex:ResponsibilitySet .

## =================================================================
## END OF NORDIC PROFILE ONTOLOGY
## =================================================================
